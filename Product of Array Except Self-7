class Solution {
    public int[] productExceptSelf(int[] nums) {
        int n=nums.length;
        int ans[]=new int[n];
        int PrL=1,PrR=1;
        for(int i=n-1; i>=0;i--){
            ans[i]=PrR;
            PrR=PrR*nums[i];
        }
        for(int i=0;i<n;i++){
            ans[i]=ans[i]*PrL;
            PrL=PrL*nums[i];
        }
        return ans;
    }
}
