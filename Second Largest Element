public class Solution {
    public int SecondLargestElement(List<int> nums) {
        int largenum = int.MinValue;
        int secondlarge = int.MinValue;
        for(int i=0; i<nums.Count; i++){
            if(nums[i]>largenum){
                secondlarge = largenum;
                largenum = nums[i];
            }
            else if(nums[i]<largenum && nums[i]>secondlarge){
                secondlarge = nums[i];
            }
        }
        return secondlarge == int.MinValue? -1: secondlarge;
    }
}
