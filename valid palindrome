class Solution {
    public boolean isPalindrome(String s) {
        if(s.isEmpty()){
            return true;
        }
        int i=0;
        int j=s.length()-1;
        while(i<=j){
            char cf=s.charAt(i);
            char cl=s.charAt(j);
            if(!Character.isLetterOrDigit(cf)){
                i++;
            } else if(!Character.isLetterOrDigit(cl)){
                j--;
            } else{
                if(Character.toLowerCase(cf)!=Character.toLowerCase(cl)){
                    return false;
                }
                i++;
                j--;
            }
        }
        return true;
    }
}
